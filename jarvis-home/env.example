# Jarvis Environment Variables
# Copy this to ~/jarvis/.env and fill in your values.
# This file is NOT committed to git.

# Home Assistant
HA_URL=http://192.168.68.113:8123
HA_TOKEN=your-home-assistant-long-lived-access-token-here

# n8n
N8N_URL=http://localhost:20003
N8N_API_KEY=your-n8n-api-key-here

# Telegram (for monitoring alerts)
TG_BOT_TOKEN=your-telegram-bot-token-here
TG_CHAT_ID=your-telegram-chat-id-here

# qBittorrent
QBT_URL=http://localhost:20008
QBT_USERNAME=admin
QBT_PASSWORD=your-qbittorrent-password-here

# Long-term memory (PostgreSQL + PGVector)
DATABASE_URL=postgresql://jarvis:your-password@localhost:20004/jarvis
OPENAI_API_KEY=your-openai-api-key-here
